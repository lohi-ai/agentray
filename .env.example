# Copy to .env (gitignored) and fill with real local values. Never commit .env.
#   set -a && . ./.env && set +a
#   /usr/local/go/bin/go test ./internal/... -run 'TestReal_|RealProvider' -v -count=1

# OpenAI-compatible endpoint for the env-gated real-provider agent tests.
# Tests skip (not fail) when these are unset, so CI stays green without creds.
AGENTRAY_TEST_OPENAI_BASE_URL=http://localhost:PORT/v1
AGENTRAY_TEST_OPENAI_API_KEY=sk-your-local-key
AGENTRAY_TEST_OPENAI_MODEL=your-model

# Sandbox images the computer_use / browser_use integration tests run in.
# Build: docker build --platform linux/amd64 -f Dockerfile.computeruse -t agentray-computeruse:latest .
#        docker build --platform linux/amd64 -f Dockerfile.browser      -t agentray-browser:latest .
AGENTRAY_SANDBOX_COMPUTER_USE_IMAGE=agentray-computeruse:latest
AGENTRAY_SANDBOX_BROWSER_IMAGE=agentray-browser:latest

# Least-privilege ClickHouse account for untrusted SELECTs (run_sql, /api/sql/run,
# saved queries). Provisioned automatically by migrateClickHouse with GRANT SELECT
# on the project DB only + readonly=2, so a table-function bypass (SELECT * FROM
# url(...)) fails with a grant error. Leave empty in dev to reuse the primary conn.
CLICKHOUSE_RO_USER=agentray_readonly
CLICKHOUSE_RO_PASSWORD=replace-with-a-random-secret

# Secret used to derive the AES-GCM key (SHA-256) that encrypts per-agent provider
# API keys at rest. Required for the chat/agent runtime to read or store agent keys.
# Use any high-entropy string locally; set a real managed secret in prod. Rotating it
# makes already-stored keys undecryptable, so rotate deliberately.
AGENT_KEY_ENC_SECRET=replace-with-a-random-secret
