# AgentRay dev — non-secret env. Secrets (POSTGRES_URL, CLICKHOUSE_PASSWORD)
# live in secret.env, written on the VM by ../fetch-secrets.sh.
HTTP_ADDR=:8080
CLICKHOUSE_ADDR=agentray-clickhouse:9000
CLICKHOUSE_DATABASE=agentray_dev
CLICKHOUSE_USER=agentray
REDIS_URL=redis://agentray-redis:6379/0
NATS_URL=nats://agentray-nats:4222
INGEST_SUBJECT=agentray.events.ingest.dev
RATE_LIMIT_PER_MINUTE=600
DEFAULT_PROJECT_NAME=LoHi dev
DEFAULT_PROJECT_API_KEY=replace_me_project_token
ALLOWED_ORIGINS=https://agentray-dev.lohi2.com
