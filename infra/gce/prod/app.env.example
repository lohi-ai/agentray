# AgentRay prod — non-secret env. Secrets (POSTGRES_URL, CLICKHOUSE_PASSWORD)
# live in secret.env, written on the VM by ../fetch-secrets.sh.
# Shares ClickHouse/Redis/NATS with dev (infra/) — separated by CH database,
# Redis DB index, and NATS subject.
HTTP_ADDR=:8080
CLICKHOUSE_ADDR=agentray-clickhouse:9000
CLICKHOUSE_DATABASE=agentray_prod
CLICKHOUSE_USER=agentray
REDIS_URL=redis://agentray-redis:6379/1
NATS_URL=nats://agentray-nats:4222
INGEST_SUBJECT=agentray.events.ingest.prod
RATE_LIMIT_PER_MINUTE=1200
DEFAULT_PROJECT_NAME=LoHi prod
DEFAULT_PROJECT_API_KEY=replace_me_project_token
ALLOWED_ORIGINS=https://agentray.lohi2.com
